{
  "expo": {
    "name": "docmaster",
    "slug": "docmaster",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "docmaster",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.tesea.docmaster"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tesea.docmaster",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F4EFE6",
          "image": "./assets/docmaster.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "android": {
            "image": "./assets/docmaster.png",
            "imageWidth": 200
          },
          "ios": {
            "image": "./assets/docmaster.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "DocMaster a besoin d'accéder à vos photos pour les documents.",
          "cameraPermission": "DocMaster a besoin d'accéder à votre appareil photo pour scanner vos documents.",
          "microphonePermission": false
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "ndkVersion": "30.0.14904198"
          }
        }
      ],
      "expo-audio",
      "react-native-document-scanner-plugin",
      ["./plugins/withNdkVersion", "30.0.14904198"]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d62d23a5-c7ac-4b7e-849a-b8fb8f194d67"
      },
      "firebaseApiKey": "AIzaSyDIGJ6nLy-LwW8RrsukLIHjPVnESugtPCc",
      "firebaseAuthDomain": "docmaster-ad853.firebaseapp.com",
      "firebaseProjectId": "docmaster-ad853",
      "firebaseStorageBucket": "docmaster-ad853.firebasestorage.app",
      "firebaseMessagingSenderId": "805201822235",
      "firebaseAppId": "1:805201822235:android:a6bcf433f4573e0b376ebe",
      "googleClientId": "805201822235-1lm5tfjtm1hic1vp7u7uslfibe11pc12.apps.googleusercontent.com"
    }
  }
}