{
  "scripts": {
    "css:watch": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css --watch",
    "build": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css --minify",
    "serve": "http-server ./src -p 5173 -a 127.0.0.1 -c-1 -o /index.html",
    "dev": "concurrently -k \"npm run css:watch\" \"npm run serve\"",
    "start": "npm run dev"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "concurrently": "^9.2.1",
    "http-server": "^14.1.1",
    "jspdf": "^4.2.1",
    "tailwindcss": "^4.1.18"
  }
}
